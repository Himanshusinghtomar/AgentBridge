{
  "name": "@agentbridge/sdk",
  "version": "0.2.0",
  "description": "Typed client for AgentBridge runtime",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --test"
  },
  "dependencies": {
    "@agentbridge/shared": "file:../shared",
    "undici": "^6.6.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
